model User {
  id              String   @id @default(uuid())
  keycloakId      String   @unique
  email           String   @unique
  firstName       String
  lastName        String
  phone           String?

  isEmailVerified Boolean  @default(false)
  activationToken String?  @unique

  addresses       Address[]
  reviews         Review[]
  orders          Order[]
  cart            Cart?
  wishlistItems   WishlistItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}